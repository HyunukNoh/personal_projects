{
  "name": "lyric_learner",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "prestart": "node scripts/generate-manifest.js",
    "start": "concurrently \"expo start\" \"node scripts/watch-songs.js\"",
    "preandroid": "node scripts/generate-manifest.js",
    "android": "expo run:android",
    "preios": "node scripts/generate-manifest.js",
    "ios": "expo run:ios --device",
    "preios:release": "node scripts/generate-manifest.js",
    "ios:release": "expo run:ios --device --configuration Release",
    "web": "expo start --web",
    "postinstall": "node scripts/generate-manifest.js",
    "prebuild": "node scripts/generate-manifest.js",
    "songs": "node scripts/generate-manifest.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-community/slider": "5.0.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "concurrently": "^9.2.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
